<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="88dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:layout_marginEnd="12dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/slate_200"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/iv_actor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/slate_200"
            android:contentDescription="@string/cd_actor_photo" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_actor_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/slate_900"
        android:textSize="12sp"
        tools:text="Tom Cruise" />

</LinearLayout>