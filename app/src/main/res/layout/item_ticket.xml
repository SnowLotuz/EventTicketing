<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeColor="@color/slate_200"
    app:strokeWidth="1dp"
    app:rippleColor="@color/accent_blue_light">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_qr_thumb"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@color/white"
            android:padding="4dp"
            android:contentDescription="@string/tickets_qr_cd"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_seat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/slate_900"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/iv_qr_thumb"
            app:layout_constraintStart_toEndOf="@id/iv_qr_thumb"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Seat A1" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/tv_seat"
            app:layout_constraintStart_toEndOf="@id/iv_qr_thumb"
            tools:text="Valid"
            tools:textColor="@color/seat_available" />

        <TextView
            android:id="@+id/tv_tap_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:text="@string/tickets_tap_hint"
            android:textColor="@color/slate_400"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/tv_status"
            app:layout_constraintStart_toEndOf="@id/iv_qr_thumb"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>