<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeColor="@color/slate_200"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_event_image"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="@color/slate_200"
            android:contentDescription="@string/cd_event_image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Wishlist heart, overlaid top-end on the image -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_wishlist"
            style="@style/Widget.Material3.Button.Icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:icon="@drawable/ic_heart_outline"
            app:iconTint="@color/status_error"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:backgroundTint="@color/white"
            app:cornerRadius="20dp"
            app:elevation="2dp"
            app:layout_constraintTop_toTopOf="@id/iv_event_image"
            app:layout_constraintEnd_toEndOf="@id/iv_event_image" />

        <TextView
            android:id="@+id/tv_event_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/slate_900"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/iv_event_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Summer Music Festival 2025" />

        <ImageView
            android:id="@+id/ic_date"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_calendar"
            app:tint="@color/slate_400"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/tv_event_title"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_event_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/slate_600"
            android:textSize="13sp"
            app:layout_constraintTop_toTopOf="@id/ic_date"
            app:layout_constraintBottom_toBottomOf="@id/ic_date"
            app:layout_constraintStart_toEndOf="@id/ic_date"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Sat, 12 Jul 2025 · 7:00 PM" />

        <ImageView
            android:id="@+id/ic_venue"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:src="@drawable/ic_location"
            app:tint="@color/slate_400"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/ic_date"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_event_venue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/slate_600"
            android:textSize="13sp"
            app:layout_constraintTop_toTopOf="@id/ic_venue"
            app:layout_constraintBottom_toBottomOf="@id/ic_venue"
            app:layout_constraintStart_toEndOf="@id/ic_venue"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Madison Square Garden, NY" />

        <TextView
            android:id="@+id/tv_event_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:textColor="@color/accent_blue"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/ic_venue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="From $20" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:textColor="@color/accent_blue"
            app:chipBackgroundColor="@color/accent_blue_light"
            app:chipStrokeWidth="0dp"
            app:chipMinHeight="28dp"
            app:ensureMinTouchTargetSize="false"
            app:layout_constraintTop_toTopOf="@id/tv_event_price"
            app:layout_constraintBottom_toBottomOf="@id/tv_event_price"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Music" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>