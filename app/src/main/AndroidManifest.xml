<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".EventTicketingApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EventTicketing">


        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.EventTicketing.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ui.detail.EventDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.admin.CreateEventActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.seat.SeatSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.checkout.CheckoutActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.admin.CheckInActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.admin.AdminEventsActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.admin.EditEventActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.admin.AdminUsersActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.profile.BookingHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.EventTicketing" />

    </application>

</manifest>